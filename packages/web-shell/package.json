{
  "name": "@agentc7/web-shell",
  "version": "0.0.0-dev",
  "description": "Embeddable Preact shell for ac7 team views — chat, roster, objectives, files, members.",
  "license": "Apache-2.0",
  "author": "Andrew Przybilla <andrewprzybilla@gmail.com>",
  "homepage": "https://github.com/agentc7/ac7#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentc7/ac7.git",
    "directory": "packages/web-shell"
  },
  "bugs": {
    "url": "https://github.com/agentc7/ac7/issues"
  },
  "keywords": [
    "ac7",
    "shell",
    "preact",
    "embeddable"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./styles.css": "./src/styles/index.css"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "clean": "rm -rf .turbo"
  },
  "dependencies": {
    "@agentc7/sdk": "workspace:*",
    "@preact/signals": "^2.9.0",
    "preact": "^10.29.1"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.0",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^25.6.0",
    "happy-dom": "^20.9.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
