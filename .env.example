# Copy this file to .env and fill in values for local development.
# .env is gitignored; .env.example is the committed template.
#
# Loaded by `pnpm dev` via Node's --env-file-if-exists flag. Operators
# running ac7 in production typically set these in their service
# manager (systemd, Docker, etc.) rather than via .env.

# ─── Server: required ──────────────────────────────────────────────

# Path to the team config file. Relative paths resolve against the
# server's CWD. Create one by copying apps/server/config.example.json
# or by running `ac7 serve` interactively to trigger the first-run
# wizard.
AC7_CONFIG_PATH=./config.dev.json

# ─── Server: optional ──────────────────────────────────────────────

# Listen address and port. Defaults below. Binding to a non-loopback
# host auto-enables self-signed HTTPS on AC7_HTTPS_PORT.
AC7_HOST=127.0.0.1
AC7_PORT=8717

# Path to the SQLite database file. Defaults to ./ac7.db.
# Use :memory: for ephemeral runs (data lost on restart).
AC7_DB_PATH=/tmp/ac7-dev.db

# Path to the agent activity-stream database (LLM exchanges, opaque
# HTTP traces). Defaults to a sibling of AC7_DB_PATH.
# AC7_ACTIVITY_DB_PATH=/tmp/ac7-activity.db

# Key-encryption key for at-rest secrets (AES-256-GCM): TOTP secrets
# and the VAPID web-push private key. 32 raw bytes, base64-encoded.
# When unset, the server generates one at ./ac7-kek.bin on first
# boot (mode 0o600). Loss of this file + the config file together
# defeats the at-rest encryption — back both up.
# AC7_KEK=

# ─── CLI: client-side ──────────────────────────────────────────────

# Bearer token for `ac7` CLI commands (push, roster, objectives, ...).
# Must match a member token in the server's team config. The server
# looks up the member by hashed token and uses its name as the
# authenticated identity.
AC7_TOKEN=ac7_dev_replace_me

# Server URL the CLI talks to. Defaults to http://127.0.0.1:8717.
# AC7_URL=http://127.0.0.1:8717

# Override path for the CLI's saved auth (device-code flow output).
# Defaults to ~/.config/ac7/auth.json.
# AC7_AUTH_CONFIG_PATH=

# ─── Telemetry: optional, OFF by default ───────────────────────────

# Enable explicitly with `ac7 telemetry enable`. See `ac7 telemetry
# preview` to inspect the exact bytes that would be sent.

# Override the receiving endpoint (useful for self-host-your-own
# aggregator or for blocking sends entirely in CI).
# AC7_TELEMETRY_ENDPOINT=https://telemetry.ac7.dev/v1/install

# Override the path of the telemetry state file. Defaults to an
# XDG / platform-appropriate location under ~/.config/ac7/.
# AC7_TELEMETRY_PATH=
