# Copy this file to .env and fill in values for local development.
# .env is gitignored; .env.example is the committed template.
#
# Loaded by `pnpm dev` via Node's --env-file-if-exists flag.

# Path to the team config file. Relative to the server's CWD
# (apps/server/ when running via `turbo dev`). Create one by copying
# apps/server/config.example.json or by running ac7-server interactively
# to trigger the first-run wizard.
AC7_CONFIG_PATH=./config.dev.json

# Token for the individual-contributor CLI (ac7 push, ac7 roster). Must
# match one of the slot tokens in the team config file above — the
# server looks up the slot by hashed token and uses its name as the
# authenticated identity.
AC7_TOKEN=ac7_dev_ic_secret

# Optional — broker listen address and port.
AC7_HOST=127.0.0.1
AC7_PORT=8717

# Optional — SQLite path. Defaults to ./ac7.db if unset.
# Use :memory: for ephemeral runs (data lost on restart).
AC7_DB_PATH=/tmp/ac7-dev.db
