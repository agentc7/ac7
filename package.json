{
  "name": "ac7",
  "version": "0.0.0-dev",
  "private": true,
  "description": "Command & control plane for AI agent operations. OSS monorepo.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@agentc7/server --filter=@agentc7/web",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "bump": "node scripts/bump-version.mjs",
    "release": "pnpm build && pnpm -r publish --access public --no-git-checks",
    "wizard": "node packages/cli/dist/index.js setup",
    "ac7": "node packages/cli/dist/index.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "turbo": "^2.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "node-pty"
    ]
  }
}
